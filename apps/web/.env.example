NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Production clinic portal — required for Google OAuth callbacks (must match Supabase redirect allow list).
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEBSITE_APP_URL=http://localhost:3001

# Hostinger SMTP — see hostinger-smtp.vercel.env.example for Vercel copy-paste (GreenCoatVets display name).
HOSTINGER_SMTP_HOST=
HOSTINGER_SMTP_PORT=465
HOSTINGER_SMTP_USER=
HOSTINGER_SMTP_PASS=
# Use "GreenCoatVets <you@yourdomain.com>" so the inbox shows the brand name.
HOSTINGER_SMTP_FROM=
# Public site: contact + appointment notifications (optional; overrides DB inbox settings)
ADMIN_NOTIFICATION_EMAIL=
CRON_SECRET=

# OpenRouter (AI blog drafting)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
