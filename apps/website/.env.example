NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Production: https://www.greencoatvets.com — used for sitemap/robots when not set in admin SEO settings.
NEXT_PUBLIC_WEBSITE_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
# Fallback if keys are not stored in DB (platform_payment_settings). Prefer configuring Razorpay in web app → Payments (super admin).
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Server-only: allows the marketing site API to read platform_payment_settings. Without it, env RAZORPAY_* above is used.
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (AI blog drafting)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# Instagram Graph API — server-only: admin "Refresh from Instagram" on /admin/settings loads latest post/reel permalinks.
# The @handle (e.g. greencoatvets) is NOT the user id — use the Instagram Business Account id from Meta (Graph API Explorer / Business Suite).
# Token: long-lived Page or System User token with permissions to read that IG account's media.
# See: https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
# Optional: default 12, max 25
# INSTAGRAM_EMBED_FETCH_LIMIT=12
# Optional: override API host/version if Meta instructs (defaults to https://graph.facebook.com/v21.0)
# INSTAGRAM_GRAPH_BASE_URL=
# INSTAGRAM_GRAPH_API_VERSION=v21.0
