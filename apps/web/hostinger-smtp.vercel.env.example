# =============================================================================
# Vercel + Hostinger SMTP (GreenCoatVets)
# =============================================================================
# Copy these into: Vercel → your project → Settings → Environment Variables
# Add to Production (and Preview if you want email from preview deploys).
#
# Sender display name: use the "Name <email>" form so recipients see "GreenCoatVets"
# in their inbox (nodemailer accepts this for HOSTINGER_SMTP_FROM).
#
# Used by:
#   - apps/web: notification email dispatch, staff portal flows that send SMTP
#   - apps/website: public contact form (if that Vercel project has the same vars)
#
# Hostinger: create an email mailbox in hPanel, then use these SMTP settings:
#   https://support.hostinger.com/en/articles/1575756-how-to-get-email-client-configuration-details
# =============================================================================

# Usually smtp.hostinger.com (confirm in hPanel → Email → Configuration)
HOSTINGER_SMTP_HOST=smtp.hostinger.com

# 465 = SSL/TLS (secure: true). 587 = STARTTLS (set secure: false in code if you switch — currently app uses secure: port === 465)
HOSTINGER_SMTP_PORT=465

# Full email address of the mailbox you created (e.g. noreply@yourdomain.com)
HOSTINGER_SMTP_USER=noreply@yourdomain.com

# Mailbox password (Vercel: store as Sensitive / encrypted)
HOSTINGER_SMTP_PASS=your-mailbox-password

# "From" for all outgoing mail: display name + same mailbox (or allowed sender)
# Example — recipients see GreenCoatVets as the sender name:
HOSTINGER_SMTP_FROM=GreenCoatVets <noreply@yourdomain.com>

# Optional: cron / internal jobs that call secured routes
# CRON_SECRET=generate-a-long-random-string
