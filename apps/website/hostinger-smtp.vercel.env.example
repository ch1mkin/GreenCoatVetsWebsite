# Marketing site (apps/website) — copy into Vercel for this project.
# Full reference (same SMTP vars): ../web/hostinger-smtp.vercel.env.example

HOSTINGER_SMTP_HOST=smtp.hostinger.com
HOSTINGER_SMTP_PORT=465
HOSTINGER_SMTP_USER=noreply@yourdomain.com
HOSTINGER_SMTP_PASS=your-mailbox-password
HOSTINGER_SMTP_FROM=GreenCoatVets <noreply@yourdomain.com>

# Receives /contact submissions and new /book appointment alerts (guest + owner).
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
